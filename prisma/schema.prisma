generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @db.VarChar(255)
  email     String   @unique @db.VarChar(255)
  passwordHash String  @map("password_hash") @db.Text
  createdAt DateTime @default(now()) @map("created_at")

  telegramChannels TelegramChannel[]
  posts            Post[]

  @@map("users")
}

model TelegramChannel {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  botToken  String   @map("bot_token") @db.Text
  chatId    String   @map("chat_id") @db.Text
  createdAt DateTime @default(now()) @map("created_at")

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  posts Post[]

  @@map("telegram_channels")
}

model Post {
  id          String    @id @default(uuid()) @db.Uuid
  userId      String    @map("user_id") @db.Uuid
  channelId   String    @map("channel_id") @db.Uuid
  title       String    @db.VarChar(255)
  caption     String    @db.Text
  imageUrl    String    @map("image_url") @db.Text
  status      String    @default("DRAFT") @db.VarChar(20)
  scheduledAt DateTime  @map("scheduled_at")
  publishedAt DateTime? @map("published_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  user  User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  channel TelegramChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  jobs   Job[]

  @@map("posts")
}

model Job {
  id        String   @id @default(uuid()) @db.Uuid
  postId    String   @map("post_id") @db.Uuid
  queueName String   @map("queue_name") @db.VarChar(100)
  status    String   @default("PENDING") @db.VarChar(20)
  attempts  Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@map("jobs")
}
