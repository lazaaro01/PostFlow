{
  "title": "PostFlow - Monitoramento",
  "uid": "postflow-dashboard",
  "tags": ["postflow"],
  "schemaVersion": 39,
  "version": 1,
  "timezone": "browser",
  "editable": true,
  "refresh": "15s",
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "timepicker": {},
  "templating": {
    "list": []
  },
  "annotations": {
    "list": []
  },
  "panels": [
    {
      "id": 1,
      "title": "Posts Criados",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "rate(posts_created_total[$__rate_interval])",
          "legendFormat": "Posts/s",
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "color": { "mode": "palette-classic" },
          "custom": {
            "showPoints": "never",
            "lineInterpolation": "smooth",
            "fillOpacity": 20
          }
        }
      },
      "description": "Taxa de criação de posts por segundo (requisição POST /posts)"
    },
    {
      "id": 2,
      "title": "Posts Publicados",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 0 },
      "targets": [
        {
          "expr": "rate(posts_published_total[$__rate_interval])",
          "legendFormat": "Posts/s",
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "color": { "mode": "palette-classic", "fixedColor": "green" },
          "custom": {
            "showPoints": "never",
            "lineInterpolation": "smooth",
            "fillOpacity": 20
          }
        }
      },
      "description": "Posts que foram publicados com sucesso no Telegram"
    },
    {
      "id": 3,
      "title": "Posts com Falha",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 0 },
      "targets": [
        {
          "expr": "rate(posts_failed_total[$__rate_interval])",
          "legendFormat": "Posts/s",
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "color": { "mode": "palette-classic", "fixedColor": "red" },
          "custom": {
            "showPoints": "never",
            "lineInterpolation": "smooth",
            "fillOpacity": 20
          }
        }
      },
      "description": "Posts que falharam ao publicar no Telegram"
    },
    {
      "id": 4,
      "title": "Jobs na Fila (BullMQ)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "bullmq_waiting_jobs",
          "legendFormat": "Aguardando",
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }
        },
        {
          "expr": "bullmq_active_jobs",
          "legendFormat": "Ativos",
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }
        },
        {
          "expr": "bullmq_failed_jobs",
          "legendFormat": "Falhos",
          "refId": "C",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "color": { "mode": "palette-classic" },
          "custom": {
            "showPoints": "never",
            "lineInterpolation": "smooth",
            "fillOpacity": 20
          }
        }
      },
      "description": "Status dos jobs na fila do BullMQ"
    },
    {
      "id": 5,
      "title": "Jobs Processados",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 8 },
      "targets": [
        {
          "expr": "rate(jobs_processed_total[$__rate_interval])",
          "legendFormat": "Jobs/s",
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "color": { "mode": "palette-classic", "fixedColor": "purple" },
          "custom": {
            "showPoints": "never",
            "lineInterpolation": "smooth",
            "fillOpacity": 20
          }
        }
      },
      "description": "Total de jobs processados pelo worker"
    },
    {
      "id": 6,
      "title": "Duração da Publicação (P99)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum(rate(publish_duration_seconds_bucket[$__rate_interval])) by (le))",
          "legendFormat": "P99",
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "palette-classic", "fixedColor": "orange" },
          "custom": {
            "showPoints": "never",
            "lineInterpolation": "smooth",
            "fillOpacity": 20
          }
        }
      },
      "description": "Percentil 99 da duração das publicações no Telegram"
    },
    {
      "id": 7,
      "title": "CPU (Processo Node)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "rate(process_cpu_user_seconds_total[$__rate_interval]) * 100",
          "legendFormat": "User",
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }
        },
        {
          "expr": "rate(process_cpu_system_seconds_total[$__rate_interval]) * 100",
          "legendFormat": "System",
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "max": 100,
          "color": { "mode": "palette-classic" },
          "custom": {
            "showPoints": "never",
            "lineInterpolation": "smooth",
            "fillOpacity": 20
          }
        }
      },
      "description": "Uso de CPU do processo Node.js"
    },
    {
      "id": 8,
      "title": "Memória (Heap do Node)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 16 },
      "targets": [
        {
          "expr": "nodejs_heap_size_bytes{space='used'}",
          "legendFormat": "Usado",
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }
        },
        {
          "expr": "nodejs_heap_size_bytes{space='total'}",
          "legendFormat": "Total",
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "color": { "mode": "palette-classic" },
          "custom": {
            "showPoints": "never",
            "lineInterpolation": "smooth",
            "fillOpacity": 20
          }
        }
      },
      "description": "Uso de memória heap do Node.js"
    },
    {
      "id": 9,
      "title": "Event Loop Lag",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 16 },
      "targets": [
        {
          "expr": "nodejs_eventloop_lag_seconds",
          "legendFormat": "Lag",
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "palette-classic", "fixedColor": "red" },
          "custom": {
            "showPoints": "never",
            "lineInterpolation": "smooth",
            "fillOpacity": 20
          }
        }
      },
      "description": "Lag do event loop do Node.js (deve ficar abaixo de 10ms)"
    }
  ]
}
